# Google AI Studio (Gemini) API key
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Alternatif isim (opsiyonel): bazı SDK'lar GOOGLE_API_KEY bekler
# GOOGLE_API_KEY=your_gemini_api_key_here

# Kullanılacak model (opsiyonel)
# Free tier için önerilen düşük model:
# GEMINI_MODEL=gemini/gemini-2.0-flash-lite
# Alternatif model:
# GEMINI_MODEL=gemini/gemini-2.0-flash

# (Opsiyonel) Frontend origin - production deploy için
# FRONTEND_ORIGIN=https://student-planner-ruddy.vercel.app
