# ─── LLM Provider (OpenRouter önerilen) ───
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat

# Gemini fallback (opsiyonel)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini/gemini-2.5-flash

# ─── LangSmith (izleme - opsiyonel) ───
# https://smith.langchain.com adresinden hesap oluştur
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=StudentPlanner-LangGraph

# ─── Frontend origin (production deploy) ───
# FRONTEND_ORIGIN=https://student-planner-ruddy.vercel.app
